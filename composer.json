{
  "name": "avinashreddy/snistoj",
  "description": "SNISTOJ - Modern Online Judge System",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Avinash Reddy",
      "email": "avinash@snistoj.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-mysqli": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "squizlabs/php_codesniffer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "SNISTOJ\\": "src/",
      "SNISTOJ\\Config\\": "config/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SNISTOJ\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-html coverage",
    "lint": "php-cs-fixer fix --dry-run",
    "lint:fix": "php-cs-fixer fix",
    "stan": "phpstan analyse",
    "sniff": "phpcs",
    "sniff:fix": "phpcbf"
  },
  "config": {
    "sort-packages": true
  }
}
